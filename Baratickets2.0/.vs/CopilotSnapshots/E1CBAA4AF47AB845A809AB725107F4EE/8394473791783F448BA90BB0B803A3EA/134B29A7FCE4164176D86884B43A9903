@inject Baratickets2._0.Data.ApplicationDbContext _dbContext
@inject Microsoft.AspNetCore.Identity.UserManager<Baratickets2._0.Models.ApplicationUser> _userManager
@{
    int eventosPendientes = 0;
    if (User.IsInRole("Admin"))
    {
        eventosPendientes = _dbContext.Eventos.Count(e => e.EstadoEvento == "PendienteAprobacion");
    }
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Baratickets 2.0</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Baratickets2._0.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .navbar {
            border-radius: 0 0 15px 15px;
        }

        .nav-link:hover {
            color: #0d6efd !important;
            transition: 0.3s;
        }

        .dropdown-menu {
            border-radius: 12px;
            padding: 10px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom shadow-sm mb-4 py-3">
            <div class="container-fluid">
                <a class="navbar-brand text-primary fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-ticket-perforated-fill"></i> Baratickets 2.0
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        @* --- CLIENTE --- *@
                        @if (User.IsInRole("Cliente"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Tickets" asp-action="MisTickets">
                                    <i class="bi bi-ticket-detailed me-1"></i> Mis Tickets
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Alquileres" asp-action="MisSolicitudes">
                                    <i class="bi bi-building me-1"></i> Mis Alquileres
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Alquileres" asp-action="Facturas">
                                    <i class="bi bi-receipt me-1"></i> Facturas
                                </a>
                            </li>
                        }

                        @* --- VALIDADOR --- *@
                        @if (User.IsInRole("Validador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Tickets" asp-action="Escanear">
                                    <i class="bi bi-qr-code-scan me-1"></i> Validar Tickets
                                </a>
                            </li>
                        }

                        @* --- ORGANIZADOR (Solo si NO es Admin para no repetir) --- *@
                        @if (User.IsInRole("Organizador") && !User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success fw-bold" asp-controller="Eventos" asp-action="Index">
                                    <i class="bi bi-calendar-check me-1"></i> Mis Eventos
                                </a>
                            </li>
                        }

                      
                        @* --- ORGANIZADOR TEMPORAL (cliente que alquiló) --- *@
                        @if (User.IsInRole("OrganizadorTemporal"))
                        {
                            var userId = _userManager.GetUserId(User);
                            var ahora = DateTime.Now;
                            var tieneSolicitudActiva = _dbContext.SolicitudesAlquiler
                            .Any(s => s.ClienteId == userId
                                   && s.Estado == "Aprobado"
                                   && s.TipoEventoAlquiler == "Publico"
                                   && s.EventoId != null
                                   && s.FechaFin >= ahora);

                            @if (tieneSolicitudActiva)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning fw-bold" asp-controller="Eventos" asp-action="MiEvento">
                                        <i class="bi bi-calendar-event me-1"></i> Mi Evento
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Alquileres" asp-action="Ganancias">
                                    <i class="bi bi-cash-coin me-1"></i> Mis Ganancias
                                </a>
                            </li>
                        }
                        @* --- 🔥 MENÚ UNIFICADO DE ADMINISTRACIÓN --- *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle btn btn-outline-primary rounded-pill px-3 py-1 border-2 fw-bold ms-lg-2"
                                   href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-shield-lock-fill me-1"></i> Panel Admin
                                </a>
                                <ul class="dropdown-menu shadow-lg border-0 mt-2">
                                    <li><h6 class="dropdown-header small text-muted text-uppercase fw-bold">Gestión Central</h6></li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="Usuarios" asp-action="Index">
                                            <i class="bi bi-people me-2 text-danger"></i> Usuarios del Sistema
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="Eventos" asp-action="Index">
                                            <i class="bi bi-calendar-event me-2 text-primary"></i> Gestión de Eventos
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="Lugares" asp-action="Index">
                                            <i class="bi bi-geo-alt me-2 text-success"></i> Gestionar Recintos
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="Alquileres" asp-action="GestionSolicitudes">
                                            <i class="bi bi-building-gear me-2 text-warning"></i> Solicitudes de Alquiler
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="Eventos" asp-action="EventosPendientes">
                                            <i class="bi bi-hourglass-split me-2 text-warning"></i> Eventos Pendientes
                                            @if (eventosPendientes > 0)
                                            {
                                                <span class="badge bg-warning text-dark ms-1 rounded-pill">@eventosPendientes</span>
                                            }
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header small text-muted text-uppercase fw-bold">Reportes y Auditoría</h6></li>
                                    <li>
                                        <a class="dropdown-item py-2 fw-bold" asp-controller="Lugares" asp-action="ReporteUso">
                                            <i class="bi bi-graph-up-arrow me-2 text-info"></i> Reporte de Uso Mensual
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        @await Html.PartialAsync("_LoginPartial")
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto bg-white py-4">
        <div class="container text-center">
            &copy; 2026 - <span class="fw-bold text-primary">Baratickets 2.0</span> - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            @if (TempData["Success"] != null)
            {
                    <text>
                    Swal.fire({
                        icon: 'success',
                        title: '¡Éxito!',
                        text: '@TempData["Success"]',
                        confirmButtonColor: '#0d6efd'
                    });
                    </text>
            }
            @if (TempData["Error"] != null)
            {
                    <text>
                    Swal.fire({
                        icon: 'error',
                        title: 'Hubo un problema',
                        text: '@TempData["Error"]',
                        confirmButtonColor: '#0d6efd'
                    });
                    </text>
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>