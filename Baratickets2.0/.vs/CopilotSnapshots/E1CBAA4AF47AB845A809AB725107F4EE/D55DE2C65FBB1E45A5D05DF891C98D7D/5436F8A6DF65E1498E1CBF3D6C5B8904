@model IEnumerable<Baratickets2._0.Models.SolicitudAlquiler>

@{
    ViewData["Title"] = "Facturas de Alquiler";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0"><i class="bi bi-receipt me-2"></i>Facturas de alquiler</h2>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info rounded-3">No tienes facturas de alquiler registradas.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th># Factura</th>
                        <th>Evento</th>
                        <th>Recinto</th>
                        <th>Fecha alquiler</th>
                        <th class="text-end">Monto</th>
                        <th>Estado solicitud</th>
                        <th>Estado pago</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td><span class="fw-bold">ALQ-@s.Id.ToString("D6")</span></td>
                            <td>@s.NombreEvento</td>
                            <td>@s.Lugar?.Nombre</td>
                            <td>@s.FechaInicio.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end fw-bold">RD$ @s.MontoAlquiler.ToString("N2")</td>
                            <td><span class="badge bg-secondary">@s.Estado</span></td>
                            <td>
                                @if (s.Orden != null && s.Orden.Reembolsado)
                                {
                                    <span class="badge bg-warning text-dark">Reembolsado</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Pagado</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>