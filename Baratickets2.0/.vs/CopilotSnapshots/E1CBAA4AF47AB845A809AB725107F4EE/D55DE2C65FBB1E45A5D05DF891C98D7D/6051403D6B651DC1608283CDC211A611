        }

        [HttpGet]
        public async Task<IActionResult> Ganancias()
        {
            var userId = _userManager.GetUserId(User);

            var solicitudes = await _context.SolicitudesAlquiler
                .Include(s => s.Lugar)
                .Include(s => s.Evento)
                    .ThenInclude(e => e.Tickets)
                .Where(s => s.ClienteId == userId
                         && s.TipoEventoAlquiler == "Publico"
                         && s.EventoId != null)
                .OrderByDescending(s => s.FechaInicio)
                .ToListAsync();

            return View(solicitudes);
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> CobrarGanancias(int id)
        {
            var userId = _userManager.GetUserId(User);
            var ahora = DateTime.Now;

            var solicitud = await _context.SolicitudesAlquiler
                .Include(s => s.Evento)
                    .ThenInclude(e => e.Tickets)
                .FirstOrDefaultAsync(s => s.Id == id && s.ClienteId == userId);

            if (solicitud == null)
                return NotFound();

            if (solicitud.TipoEventoAlquiler != "Publico" || solicitud.EventoId == null)
            {
                TempData["Error"] = "Esta solicitud no aplica para cobro de ganancias.";
                return RedirectToAction(nameof(Ganancias));
            }

            if (solicitud.GananciasCobradas)
            {
                TempData["Error"] = "Las ganancias de este evento ya fueron cobradas.";
                return RedirectToAction(nameof(Ganancias));
            }

            if (string.IsNullOrWhiteSpace(solicitud.CuentaGanancias))
            {
                TempData["Error"] = "Debes configurar primero tu método de cobro de ganancias.";
                return RedirectToAction(nameof(Ganancias));
            }

            if (solicitud.FechaFin > ahora)
            {
                TempData["Error"] = "Solo puedes cobrar ganancias cuando el evento haya finalizado.";
                return RedirectToAction(nameof(Ganancias));
            }

            if (solicitud.Estado == "Cancelado" || solicitud.Estado == "Rechazado")
            {
                TempData["Error"] = "No puedes cobrar ganancias para una solicitud cancelada o rechazada.";
                return RedirectToAction(nameof(Ganancias));
            }

            var totalGanado = solicitud.Evento?.Tickets?
                .Where(t => t.Estado != "Devuelto")
                .Sum(t => t.PrecioPagado) ?? 0;

            if (totalGanado <= 0)
            {
                TempData["Error"] = "Este evento no tiene ganancias disponibles para cobrar.";
                return RedirectToAction(nameof(Ganancias));
            }

            solicitud.GananciasCobradas = true;
            solicitud.FechaCobroGanancias = ahora;
            solicitud.MontoGananciasCobradas = totalGanado;

            await _context.SaveChangesAsync();

            TempData["Success"] = $"Solicitud de cobro registrada por RD$ {totalGanado:N2}. Se procesará a tu método configurado.";
            return RedirectToAction(nameof(Ganancias));
        }
    }
