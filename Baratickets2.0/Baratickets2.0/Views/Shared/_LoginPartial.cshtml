@using Microsoft.AspNetCore.Identity
@using Baratickets2._0.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    // Detectamos la página actual de Identity
    var activePage = ViewContext.RouteData.Values["Page"]?.ToString() ?? "";
}

<ul class="navbar-nav align-items-center">
@if (SignInManager.IsSignedIn(User))
{
    @* --- SECCIÓN CUANDO YA ESTÁ LOGUEADO --- *@
    var user = await UserManager.GetUserAsync(User);
    var nombre = user?.NombreCompleto ?? User.Identity?.Name;

        <li class="nav-item">
            <a class="nav-link text-dark fw-bold" asp-controller="Usuarios" asp-action="MiCuenta">
                <i class="bi bi-person-circle"></i> Mi Cuenta
            </a>
        </li>
    <li class="nav-item">
        <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button id="logout" type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                Salir
            </button>
        </form>
    </li>
}
else
{
    @* --- SECCIÓN CUANDO NO ESTÁ LOGUEADO --- *@
    @* Si NO estamos en Login Y TAMPOCO estamos en Register, mostramos los botones *@
    if (activePage != "/Account/Login" && activePage != "/Account/Register")
    {
        <li class="nav-item">
            <a class="nav-link text-dark fw-bold me-2" id="register" asp-area="Identity" asp-page="/Account/Register">Registrarse</a>
        </li>
        <li class="nav-item">
            <a class="btn btn-primary text-white px-4 rounded-pill shadow-sm" id="login" asp-area="Identity" asp-page="/Account/Login">Iniciar Sesión</a>
        </li>
    }
}
</ul>