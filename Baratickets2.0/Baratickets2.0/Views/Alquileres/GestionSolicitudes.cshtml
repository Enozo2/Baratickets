@model IEnumerable<Baratickets2._0.Models.SolicitudAlquiler>

@{
    ViewData["Title"] = "Gestión de Solicitudes";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-building-gear"></i> Gestión de Solicitudes de Alquiler</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3">
            <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="card shadow border-0" style="border-radius: 15px;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Cliente</th>
                        <th>Evento</th>
                        <th>Recinto</th>
                        <th class="text-center">Fecha</th>
                        <th class="text-center">Horas</th>
                        <th class="text-end">Monto</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var s in Model)
                        {
                            // Lógica de colores de Badge actualizada
                            var badgeColor = s.Estado == "Aprobado" ? "success" :
                            s.Estado == "Rechazado" ? "danger" :
                            s.Estado == "Terminado" ? "secondary" : "warning text-dark";
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-2"
                                             style="width: 32px; height: 32px; font-size: 0.8rem; font-weight: bold;">
                                            @(s.Cliente?.NombreCompleto?.Substring(0, 1).ToUpper() ?? "U")
                                        </div>
                                        <div>
                                            <span class="small fw-bold d-block">@s.Cliente?.NombreCompleto</span>
                                            <span class="text-muted" style="font-size: 0.7rem;">@s.Cliente?.Email</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-bold small">@s.NombreEvento</span>
                                    <small class="text-muted d-block">@s.DescripcionEvento</small>
                                </td>
                                <td><span class="badge bg-info text-dark">@s.Lugar?.Nombre</span></td>
                                <td class="text-center small">
                                    @s.FechaInicio.ToString("dd/MM/yyyy")<br />
                                    <span class="text-muted">@s.FechaInicio.ToString("HH:mm") - @s.FechaFin.ToString("HH:mm")</span>
                                </td>
                                <td class="text-center">
                                    @((s.FechaFin - s.FechaInicio).TotalHours.ToString("0.0"))h
                                </td>
                                <td class="text-end fw-bold">RD$ @s.MontoAlquiler.ToString("N0")</td>
                                <td class="text-center">
                                    <span class="badge bg-@badgeColor">@s.Estado</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        @if (s.Estado == "Pendiente")
                                        {
                                            <form asp-action="Aprobar" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@s.Id" />
                                                <button type="submit" class="btn btn-success btn-sm rounded-pill">
                                                    <i class="bi bi-check-lg"></i> Aprobar
                                                </button>
                                            </form>
                                            <button type="button" class="btn btn-danger btn-sm rounded-pill"
                                                    onclick="rechazarSolicitud(@s.Id)">
                                                <i class="bi bi-x-lg"></i> Rechazar
                                            </button>
                                        }
                                        @* Nueva acción: Terminar (solo si ya está aprobado) *@
                                        else if (s.Estado == "Aprobado")
                                        {
                                            <form asp-action="Terminar" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@s.Id" />
                                                <button type="submit" class="btn btn-secondary btn-sm rounded-pill">
                                                    <i class="bi bi-flag-fill me-1"></i> Terminar
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <i class="bi bi-inbox text-muted d-block mb-2" style="font-size: 2rem;"></i>
                                <p class="text-muted">No hay solicitudes registradas.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Modal para rechazar con motivo *@
<div class="modal fade" id="modalRechazar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 15px;">
            <div class="modal-header bg-danger text-white border-0" style="border-radius: 15px 15px 0 0;">
                <h5 class="modal-title fw-bold"><i class="bi bi-x-circle me-2"></i> Rechazar Solicitud</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formRechazar" asp-action="Rechazar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="rechazarId" name="id" />
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Motivo del rechazo</label>
                        <textarea name="motivoRechazo" class="form-control" rows="3"
                                  style="border-radius: 10px;"
                                  placeholder="Explica por qué se rechaza la solicitud..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-danger w-100 rounded-pill fw-bold">
                        Confirmar Rechazo
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function rechazarSolicitud(id) {
        document.getElementById('rechazarId').value = id;
        new bootstrap.Modal(document.getElementById('modalRechazar')).show();
    }
</script>