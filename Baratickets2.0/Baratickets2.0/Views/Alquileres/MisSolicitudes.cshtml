@model IEnumerable<Baratickets2._0.Models.SolicitudAlquiler>

@{
    ViewData["Title"] = "Mis Solicitudes";
    bool tieneSolicitudActiva = Model.Any(s => s.Estado == "Pendiente" || s.Estado == "Aprobado");
}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-building"></i> Mis Solicitudes de Alquiler</h2>
        @if (!tieneSolicitudActiva)
        {
            <a asp-action="Solicitar" class="btn btn-primary rounded-pill">
                <i class="bi bi-plus-circle me-2"></i> Nueva Solicitud
            </a>
        }
    </div>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3">
            <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <h5>No tienes solicitudes aún.</h5>
            <a asp-action="Solicitar" class="btn btn-primary mt-2">Solicitar un espacio</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var s in Model)
            {
                var badgeColor = s.Estado == "Aprobado" ? "success" :
                s.Estado == "Rechazado" ? "danger" : "warning text-dark";

                <div class="col-md-6 mb-4">
                    <div class="card shadow border-0 h-100" style="border-radius: 15px;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="fw-bold mb-0">@s.NombreEvento</h5>
                                <span class="badge bg-@badgeColor">@s.Estado</span>
                            </div>

                            <p class="text-muted small mb-2">
                                <i class="bi bi-geo-alt-fill text-primary me-1"></i> @s.Lugar?.Nombre
                            </p>
                            <p class="text-muted small mb-2">
                                <i class="bi bi-calendar me-1"></i>
                                @s.FechaInicio.ToString("dd/MM/yyyy HH:mm") — @s.FechaFin.ToString("HH:mm")
                            </p>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-clock me-1"></i>
                                @((s.FechaFin - s.FechaInicio).TotalHours.ToString("0.0")) horas
                            </p>

                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="fw-bold text-primary mb-0">RD$ @s.MontoAlquiler.ToString("N0")</h5>
                                @if (s.Estado == "Aprobado")
                                {
                                    @if (s.EventoId == null && User.IsInRole("Organizador"))
                                    {
                                        <a asp-controller="Eventos" asp-action="Create" class="btn btn-success btn-sm rounded-pill">
                                            <i class="bi bi-plus-circle me-1"></i> Crear Evento
                                        </a>
                                    }
                                    else if (s.EventoId != null)
                                    {
                                        <a asp-controller="Eventos" asp-action="Dashboard" asp-route-id="@s.EventoId" class="btn btn-primary btn-sm rounded-pill">
                                            <i class="bi bi-graph-up me-1"></i> Ver Dashboard
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Eventos" asp-action="CrearDesdeAlquiler" asp-route-id="@s.Id" class="btn btn-warning btn-sm rounded-pill text-dark fw-bold shadow-sm">
                                            <i class="bi bi-plus-circle me-1"></i> Crear Evento
                                        </a>
                                    }
                                }
                            </div>

                            @if (s.Estado == "Rechazado" && !string.IsNullOrEmpty(s.MotivoRechazo))
                            {
                                <div class="alert alert-danger mt-3 mb-0 p-2 rounded-3">
                                    <small><i class="bi bi-info-circle me-1"></i> <strong>Motivo:</strong> @s.MotivoRechazo</small>
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-white border-0 pb-3">
                            <small class="text-muted">Solicitado: @s.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>