@model Baratickets2._0.Models.SolicitudAlquiler

@{
    ViewData["Title"] = "Detalle de Factura";
    var numeroFactura = $"ALQ-{Model.Id:D6}";
}

<div class="container mt-4 factura-wrap">
    <div class="d-flex justify-content-between align-items-center mb-3 no-print">
        <h3 class="fw-bold mb-0"><i class="bi bi-receipt-cutoff me-2"></i>Factura @numeroFactura</h3>
        <div class="d-flex gap-2">
            <a asp-action="Facturas" class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>
            <button class="btn btn-danger rounded-pill" onclick="window.print()">
                <i class="bi bi-filetype-pdf me-1"></i>Guardar como PDF
            </button>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 p-4 factura-box">
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h4 class="fw-bold text-primary mb-1">Baratickets 2.0</h4>
                <small class="text-muted">Comprobante de alquiler</small>
            </div>
            <div class="text-end">
                <div class="fw-bold">@numeroFactura</div>
                <small class="text-muted">Emitida: @Model.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</small>
            </div>
        </div>

        <hr />

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <div><strong>Evento:</strong> @Model.NombreEvento</div>
                <div><strong>Tipo:</strong> @Model.TipoEventoAlquiler</div>
                <div><strong>Recinto:</strong> @Model.Lugar?.Nombre</div>
            </div>
            <div class="col-md-6">
                <div><strong>Fecha inicio:</strong> @Model.FechaInicio.ToString("dd/MM/yyyy HH:mm")</div>
                <div><strong>Fecha fin:</strong> @Model.FechaFin.ToString("dd/MM/yyyy HH:mm")</div>
                <div><strong>Estado:</strong> @Model.Estado</div>
            </div>
        </div>

        <table class="table table-borderless align-middle mb-0">
            <thead class="border-bottom">
                <tr>
                    <th>Concepto</th>
                    <th class="text-end">Monto</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Alquiler de espacio</td>
                    <td class="text-end">RD$ @Model.MontoAlquiler.ToString("N2")</td>
                </tr>
            </tbody>
            <tfoot class="border-top">
                <tr>
                    <th>Total pagado</th>
                    <th class="text-end text-success">RD$ @Model.MontoAlquiler.ToString("N2")</th>
                </tr>
            </tfoot>
        </table>

        @if (Model.Orden != null)
        {
            <div class="mt-3 small text-muted">
                <div><strong>Transacción:</strong> @Model.Orden.TransaccionPasarelaId</div>
                <div><strong>Estado pago:</strong> @(Model.Orden.Reembolsado ? "Reembolsado" : "Pagado")</div>
            </div>
        }
    </div>
</div>

<style>
    @@media print {
        .no-print { display: none !important; }
        body { background: #fff !important; }
        .factura-box { box-shadow: none !important; border: 1px solid #ddd !important; }
    }
</style>

@if ((bool?)ViewBag.Imprimir == true)
{
    <script>
        window.addEventListener('load', function () {
            window.print();
        });
    </script>
}