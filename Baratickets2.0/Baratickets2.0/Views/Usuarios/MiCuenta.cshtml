@model Baratickets2._0.Models.MiCuentaViewModel
@{
    ViewData["Title"] = "Configuración de Mi Cuenta";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        @* --- TARJETA DE PERFIL --- *@
        <div class="col-md-5">
            <div class="card shadow-sm border-0 text-center p-4 mb-4">
                <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center mb-3 mx-auto" style="width: 100px; height: 100px; font-size: 2.5rem;">
                    @(Model.Usuario.UserName?.Substring(0, 1).ToUpper())
                </div>
                <h3 class="fw-bold">@Model.Usuario.NombreCompleto</h3>
                <p class="text-muted">@Model.Usuario.Email</p>

                <hr />

                <h6 class="text-start fw-bold mb-3">Opciones de Cuenta</h6>
                <div class="d-grid gap-2">
                    @* Enlace para cambiar Nombre y Datos (Página Manage de Identity) *@
                    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-primary rounded-pill transition hover-shadow">
                        <i class="bi bi-person-gear"></i> Cambiar Nombre / Datos
                    </a>

                    @* Enlace para cambiar Contraseña (Página ChangePassword de Identity) *@
                    <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="btn btn-outline-danger rounded-pill transition hover-shadow">
                        <i class="bi bi-shield-lock"></i> Cambiar Contraseña
                    </a>
                </div>
            </div>
        </div>

        @* --- RESUMEN DE ACTIVIDAD --- *@
        @if (User.IsInRole("Cliente"))
        {
        <div class="col-md-7">
            <div class="card shadow-sm border-0 p-4">
                <h5 class="fw-bold text-primary mb-4 border-bottom pb-2">Resumen de Actividad</h5>

                <div class="text-center py-4 bg-light rounded-3 mb-4">
                    <h1 class="display-4 fw-bold">@Model.TotalTicketsComprados</h1>
                    <p class="text-muted mb-0">Tickets Adquiridos</p>
                </div>

                <div class="text-end">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-link text-decoration-none text-muted">
                        <i class="bi bi-arrow-left-circle"></i> Volver a Eventos
                    </a>
                </div>
            </div>
        </div>
   
}