@using Microsoft.AspNetCore.Identity
@inject UserManager<Baratickets2._0.Models.ApplicationUser> UserManager
@model IEnumerable<Baratickets2._0.Models.ApplicationUser>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}
@* Agrega esto justo antes de que empiece la tarjeta del Panel de Roles *@
<div class="text-end mb-3">
    <a asp-action="Crear" class="btn btn-success rounded-pill shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Nuevo Usuario
    </a>
</div>
<div class="container mt-4">
    <div class="card shadow border-0" style="border-radius: 15px;">
        <div class="card-header bg-dark text-white" style="border-radius: 15px 15px 0 0;">
            <h3 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Panel de Administración de Roles</h3>
        </div>
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol Actual</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usuario in Model)
                    {
                        <tr>
                            <td>@usuario.NombreCompleto</td>
                            <td>@usuario.Email</td>
                            <td>
                                @{
                                    var roles = await UserManager.GetRolesAsync(usuario);
                                    var rolPrincipal = roles.FirstOrDefault() ?? "Sin Rol";

                                    var colorBadge = rolPrincipal switch
                                    {
                                        "Admin" => "bg-danger",
                                        "Organizador" => "bg-success",
                                        "Validador" => "bg-warning text-dark",
                                        _ => "bg-info text-dark"
                                    };
                                }
                                <span class="badge @colorBadge">@rolPrincipal</span>
                            </td>
                            @* Reemplaza las columnas de Actualizar y Eliminar por esta única columna *@
                            <td class="text-center">
                                <div class="d-flex align-items-center justify-content-center gap-2">

                                    @* Formulario de Actualizar *@
                                    <form asp-action="AsignarRol" method="post" class="d-flex align-items-center gap-2 m-0">
                                        <input type="hidden" name="userId" value="@usuario.Id" />
                                        <select name="nombreRol" class="form-select form-select-sm rounded-pill" style="width: auto;">
                                            <option value="Cliente">Cliente</option>
                                            <option value="Organizador">Organizador</option>
                                            <option value="Validador">Validador</option>
                                            <option value="Admin">Admin</option>
                                        </select>
                                        <button type="submit" class="btn btn-primary btn-sm rounded-pill px-3">
                                            Actualizar
                                        </button>
                                    </form>

                                    @* Botón de Eliminar pegado al de Actualizar *@
                                    <form id="formEliminar-@usuario.Id" asp-action="EliminarUsuario" asp-route-id="@usuario.Id" method="post" class="m-0">
                                        <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3" onclick="confirmarEliminacion('@usuario.Id')">
                                            <i class="bi bi-trash3-fill"></i> Eliminar
                                        </button>
                                    </form>

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmarEliminacion(id) {
            Swal.fire({
                title: '¿Estás seguro?',
                text: "Esta acción eliminará al usuario permanentemente.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('formEliminar-' + id).submit();
                }
            })
        }
    </script>
}