@model IEnumerable<Baratickets2._0.Models.Evento>

<div class="container mt-5">
    @* Cabecera Minimalista *@
    <div class="text-center mb-5 animate__animated animate__fadeIn">
        <h1 class="fw-bold text-primary display-5">Cartelera</h1>
        <p class="text-muted fs-5">Descubre experiencias inolvidables en BaraTickets 2.0.</p>
    </div>

    @* Buscador Estético *@
    <div class="row justify-content-center mb-5">
        <div class="col-md-7">
            <div class="input-group shadow-sm border rounded-pill overflow-hidden bg-white">
                <span class="input-group-text bg-white border-0 ps-4">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" id="inputBusqueda" class="form-control border-0 py-3 ps-2"
                       placeholder="Busca artistas, eventos o ciudades..." autocomplete="off">
            </div>
        </div>
    </div>

    @* Contenedor de Tarjetas *@
    <div class="row" id="contenedorEventos">
        <div id="sinResultados" class="col-12 text-center py-5" style="display: none;">
            <i class="bi bi-search display-1 text-muted opacity-25"></i>
            <h3 class="mt-3 text-muted fw-light">No hay eventos que coincidan con tu búsqueda.</h3>
        </div>

        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-emoji-frown display-1 text-muted opacity-25"></i>
                <h3 class="mt-3 text-muted fw-light">No hay eventos registrados actualmente.</h3>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4 tarjeta-evento">
                    <div class="card h-100 shadow-sm border-0 transition-hover" style="border-radius: 25px; overflow: hidden;">

                        @* Imagen con Badge Dinámico *@
                        <div class="position-relative overflow-hidden" style="height: 240px;">
                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                <img src="@item.ImagenUrl" class="card-img-top img-zoom" alt="@item.Nombre">
                            }
                            else
                            {
                                <div class="bg-light text-muted d-flex align-items-center justify-content-center h-100">
                                    <i class="bi bi-image" style="font-size: 3rem;"></i>
                                </div>
                            }
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge bg-white text-dark shadow-sm py-2 px-3 fw-bold rounded-4 opacity-95">
                                    <i class="bi bi-calendar-event text-primary me-1"></i> @item.FechaEvento.ToString("dd MMM")
                                </span>
                            </div>
                        </div>

                        @* Cuerpo de la Tarjeta *@
                        <div class="card-body p-4 d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark mb-2">@item.Nombre</h5>
                            <p class="text-muted small mb-3 flex-grow-1 line-clamp-2">
                                @item.Descripcion
                            </p>

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div>
                                    <p class="text-muted small mb-0">Desde</p>
                                    @* LÓGICA DINÁMICA: Busca el precio más bajo de las categorías *@
                                    <span class="h5 fw-bold text-primary mb-0">
                                        @if (item.CategoriasTickets != null && item.CategoriasTickets.Any())
                                        {
                                            @:RD$ @item.CategoriasTickets.Min(c => c.Precio).ToString("N0")
                                        }
                                        else
                                        {
                                            @:TBA
                                        }
                                    </span>
                                </div>
                                <div class="text-end">
                                    <span class="badge rounded-pill bg-light text-secondary border px-3 py-2">
                                        <i class="bi bi-geo-alt-fill text-danger me-1"></i> @item.Direccion
                                    </span>
                                </div>
                            </div>

                            <div class="d-grid">
                                <a asp-controller="Eventos" asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-primary btn-lg rounded-pill shadow-sm fw-bold py-2 transition">
                                    Reservar Entradas
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    /* Estilos Premium */
    .transition-hover {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
    }

        .transition-hover:hover {
            transform: translateY(-12px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.12) !important;
        }

    .img-zoom {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .transition-hover:hover .img-zoom {
        transform: scale(1.15);
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .tarjeta-oculta {
        opacity: 0 !important;
        transform: scale(0.9) translateY(20px) !important;
        pointer-events: none;
    }

    .rounded-4 {
        border-radius: 12px !important;
    }

    .opacity-95 {
        opacity: 0.95;
    }
</style>
