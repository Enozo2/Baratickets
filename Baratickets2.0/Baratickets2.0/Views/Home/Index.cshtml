@model IEnumerable<Baratickets2._0.Models.Evento>

<div class="container mt-5">
    @* Cabecera Minimalista *@
    <div class="text-center mb-5 animate__animated animate__fadeIn">
        <h1 class="fw-bold text-primary display-5">Cartelera</h1>
        <p class="text-muted fs-5">Descubre experiencias inolvidables en la Villa Olímpica con BaraTickets 2.0.</p>
    </div>

    @* Buscador Estético *@
    <div class="row justify-content-center mb-5">
        <div class="col-md-7">
            <div class="input-group shadow-sm border rounded-pill overflow-hidden bg-white">
                <span class="input-group-text bg-white border-0 ps-4">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" id="inputBusqueda" class="form-control border-0 py-3 ps-2"
                       placeholder="Busca artistas, eventos o pabellones..." autocomplete="off">
            </div>
        </div>
    </div>

    @* Contenedor de Tarjetas *@
    <div class="row" id="contenedorEventos">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-emoji-frown display-1 text-muted opacity-25"></i>
                <h3 class="mt-3 text-muted fw-light">No hay eventos registrados actualmente.</h3>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4 tarjeta-evento">
                    <div class="card h-100 shadow-sm border-0 transition-hover" style="border-radius: 25px; overflow: hidden;">

                        @* Imagen con Badge Dinámico *@
                        <div class="position-relative overflow-hidden" style="height: 240px;">
                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                <img src="@item.ImagenUrl" class="card-img-top img-zoom" alt="@item.Nombre">
                            }
                            else
                            {
                                <div class="bg-light text-muted d-flex align-items-center justify-content-center h-100">
                                    <i class="bi bi-image" style="font-size: 3rem;"></i>
                                </div>
                            }
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge bg-white text-dark shadow-sm py-2 px-3 fw-bold rounded-4 opacity-95">
                                    <i class="bi bi-calendar-event text-primary me-1"></i> @item.FechaInicio.ToString("dd MMM")
                                </span>
                            </div>
                        </div>

                        @* Cuerpo de la Tarjeta (Diseño Premium y Organizado) *@
                        <div class="card-body p-4 d-flex flex-column" style="background: #fff;">

                            @* 🔥 Título del Evento *@
                            <h4 class="card-title fw-bold text-dark mb-3 text-truncate" title="@item.Nombre">@item.Nombre</h4>

                            @* 🗓️ Bloque de Tiempo y Lugar (Traducción a Español) *@
                            <div class="mb-3 border-bottom pb-3">
                                <div class="d-flex align-items-center mb-2 text-muted">
                                    <i class="bi bi-calendar3 me-2 text-primary opacity-75"></i>
                                    <span class="small fw-bold text-uppercase">
                                        @* Forzamos el idioma a español para el nombre del día y mes *@
                                        @item.FechaInicio.ToString("ddd, d MMMM yyyy", new System.Globalization.CultureInfo("es-ES"))
                                    </span>
                                </div>

                                <div class="d-flex align-items-center mb-2 text-muted">
                                    <i class="bi bi-clock me-2 text-primary opacity-75"></i>
                                    <span class="small">
                                        @* Cambiamos AM/PM por el formato que prefieras *@
                                        @item.FechaInicio.ToString("h:mm tt") - @item.FechaFin.ToString("h:mm tt")
                                    </span>
                                </div>

                                <div class="d-flex align-items-center text-danger fw-bold">
                                    <i class="bi bi-geo-alt-fill me-2"></i>
                                    <span class="small">@(item.Lugar?.Nombre ?? "Recinto por confirmar")</span>
                                </div>
                            </div>

                            @* 👤 Organizador (Estilo sutil) *@
                        <div class="d-flex align-items-center mb-3 bg-light p-2 rounded-pill border">
                            <i class="bi bi-person-circle fs-5 me-2 text-secondary"></i>
                            <div class="small text-muted">
                                Organizado por:
                                <span class="fw-bold text-dark">
                                    @* Prioridad: 1. Campo Organizacion, 2. UserName, 3. Staff por defecto *@
                                    @(string.IsNullOrWhiteSpace(item.Organizacion)
                                                                    ? (item.Organizador?.UserName?.Split('@')[0] ?? "Baratikcet Staff")
                                                                    : item.Organizacion)
                            </span>
                        </div>
                    </div>

                            @* 📝 Descripción (line-clamp-2) *@
                            <p class="text-muted small mb-4 flex-grow-1 line-clamp-2 fw-light">
                                @item.Descripcion
                            </p>

                            @* 💰 Precio y Botón (Alineados profesionalmente) *@
                            <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                                <div>
                                    <p class="text-muted small mb-0 fw-light" style="font-size: 0.75rem;">Entradas desde</p>
                                    <span class="h4 fw-bolder text-primary mb-0">
                                        @if (item.CategoriasTickets != null && item.CategoriasTickets.Any())
                                        {
                                            @:RD$ @item.CategoriasTickets.Min(c => c.Precio).ToString("N0")
                                        }
                                        else
                                        {
                                            @:TBA
                                        }
                                    </span>
                                </div>

                                <a asp-controller="Eventos" asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-primary btn-lg rounded-pill shadow fw-bold px-4 py-2 transition-hover">
                                    Ver Entradas
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("inputBusqueda").addEventListener("keyup", function () {
            let filtro = this.value.toLowerCase();
            let tarjetas = document.querySelectorAll(".tarjeta-evento");
            tarjetas.forEach(t => {
                let texto = t.innerText.toLowerCase();
                t.style.display = texto.includes(filtro) ? "" : "none";
            });
        });
    </script>
}

<style>
    .transition-hover {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
    }

        .transition-hover:hover {
            transform: translateY(-12px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.12) !important;
        }

    .img-zoom {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .transition-hover:hover .img-zoom {
        transform: scale(1.15);
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .rounded-4 {
        border-radius: 12px !important;
    }

    .opacity-95 {
        opacity: 0.95;
    }
</style>