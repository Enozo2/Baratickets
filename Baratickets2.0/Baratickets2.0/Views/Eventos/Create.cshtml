@model Baratickets2._0.Models.Evento

@{
    ViewData["Title"] = "Crear Evento";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 p-4" style="border-radius: 20px;">
                <h2 class="text-primary fw-bold mb-4">Configuración del Nuevo Evento</h2>

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    @* --- Datos Básicos --- *@
                   
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="Nombre" class="form-label fw-bold"></label>
                            <input asp-for="Nombre" class="form-control" placeholder="Nombre del evento" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label class="control-label fw-bold">Organizador</label>
                            <input asp-for="Organizacion" class="form-control" placeholder="Ej: Universidad Autónoma, Club Deportivo, etc." />
                            <span asp-validation-for="Organizacion" class="text-danger"></span>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label asp-for="Descripcion" class="form-label fw-bold"></label>
                            <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Seleccionar Recinto de Villa Olímpica</label>
                        <select asp-for="LugarId" class="form-select shadow-sm" asp-items="ViewBag.LugarId">
                            <option value="">-- Seleccione un lugar --</option>
                        </select>
                    </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Fecha del Evento</label>
                            <input type="date" name="fechaSolo" class="form-control" required />
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Hora de Inicio</label>
                                <input type="time" name="horaInicio" class="form-control" required />
                            </div>

                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Hora de Finalización</label>
                                <input type="time" name="horaFin" class="form-control" required />
                            </div>
                        </div>
                    <div class="mb-4">
                        <label asp-for="ImagenUrl" class="form-label fw-bold">Link del Flyer</label>
                        <input asp-for="ImagenUrl" class="form-control" id="urlInput" />

                        @* VISTA PREVIA DE LA IMAGEN *@
                        <div class="mt-3 text-center">
                            <img id="previewImagen" src="#" alt="Vista previa"
                                 style="max-width: 100%; height: 200px; display: none; border-radius: 10px; border: 1px solid #ddd; object-fit: cover;" />
                        </div>
                    </div>

                    @* --- SECCIÓN DINÁMICA DE CATEGORÍAS --- *@
                    <div class="bg-light p-4 rounded-4 mb-4 border">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-tags-fill me-2"></i>Segmentos de Boletas</h5>
                            <button type="button" id="btnAddCategory" class="btn btn-sm btn-dark rounded-pill px-3">
                                <i class="bi bi-plus-lg"></i> Agregar Segmento
                            </button>
                        </div>

                        <div id="categoriesContainer">
                            @* Aquí se insertarán las filas dinámicamente *@
                        </div>
                        <small class="text-muted">Agrega nombres como: General, VIP, Lado A, etc.</small>
                    </div>

                    <div class="form-group d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill shadow">Guardar Evento</button>
                        <a asp-action="Index" class="btn btn-light btn-lg rounded-pill">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // --- 1. LÓGICA DINÁMICA DE SEGMENTOS (BOLETAS) ---
        let categoryIndex = 0;
        const btnAdd = document.getElementById('btnAddCategory');
        const container = document.getElementById('categoriesContainer');

        if (btnAdd) {
            btnAdd.addEventListener('click', function () {
                const html = `
                    <div class="row g-2 mb-2 animate__animated animate__fadeIn category-row">
                        <div class="col-md-5">
                            <input name="CategoriasTickets[${categoryIndex}].Nombre" class="form-control" placeholder="Nombre (Ej: VIP)" required />
                        </div>
                        <div class="col-md-3">
                            <input name="CategoriasTickets[${categoryIndex}].Precio" type="number" step="0.01" class="form-control" placeholder="Precio" required />
                        </div>
                        <div class="col-md-3">
                            <input name="CategoriasTickets[${categoryIndex}].Capacidad" type="number" class="form-control" placeholder="Cant." required />
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-outline-danger w-100 border-0" onclick="this.parentElement.parentElement.remove()">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', html);
                categoryIndex++;
            });

            // Generar la primera fila automáticamente al cargar la página
            btnAdd.click();
        }

        // --- 2. LÓGICA VISTA PREVIA DEL FLYER ---
        const inputUrl = document.getElementById('urlInput');
        const preview = document.getElementById('previewImagen');

        if (inputUrl && preview) {
            inputUrl.addEventListener('input', function () {
                let url = this.value;
                if (url) {
                    preview.src = url;
                    preview.style.display = "block";
                    preview.onerror = function() { this.style.display = "none"; };
                } else {
                    preview.style.display = "none";
                }
            });
        }
    </script>
    <script>
        const inicio = document.querySelector('input[name="FechaInicio"]');
        const fin = document.querySelector('input[name="FechaFin"]');

        inicio.addEventListener('change', () => {
            // Obligamos a que la fecha de fin sea al menos 1 hora después del inicio
            if (inicio.value) {
                fin.min = inicio.value;
            }
        });

        fin.addEventListener('change', () => {
            if (fin.value < inicio.value) {
                alert("La hora de finalización no puede ser antes que la de inicio.");
                fin.value = "";
            }
        });
    </script>
}