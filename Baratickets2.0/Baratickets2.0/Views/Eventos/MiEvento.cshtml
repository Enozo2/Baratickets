@model IEnumerable<Baratickets2._0.Models.Evento>

@{
    ViewData["Title"] = "Mi Evento";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="text-warning fw-bold mb-0">Mi Evento</h1>
            <p class="text-muted">Gestiona el evento de tu alquiler aprobado</p>
        </div>

        @if (!(bool)ViewBag.TieneEventoAlquiler)
        {
            <a asp-action="Create" class="btn btn-warning shadow-sm rounded-pill px-4 text-dark">
                <i class="bi bi-plus-circle-fill me-2"></i> Crear Mi Evento
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center rounded-4 py-5">
            <i class="bi bi-calendar-x d-block mb-2" style="font-size: 3rem;"></i>
            <h5>Aún no has creado tu evento.</h5>
            <a asp-action="Create" class="btn btn-warning mt-2 rounded-pill text-dark fw-bold px-4">
                <i class="bi bi-plus-circle me-2"></i> Crear Mi Evento
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow border-0" style="border-radius: 20px; overflow: hidden;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold text-dark mb-0">@item.Nombre</h5>
                                <div class="d-flex flex-column gap-1 align-items-end">
                                    <span class="badge bg-light text-primary border">ID: @item.Id</span>
                                    @if (item.EstadoEvento == "PendienteAprobacion")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-hourglass-split me-1"></i> Pendiente
                                        </span>
                                    }
                                    else if (item.EstadoEvento == "Rechazado")
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-x-circle me-1"></i> Rechazado
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i> Publicado
                                        </span>
                                    }
                                </div>
                            </div>

                            @* Motivo de rechazo si aplica *@
                            @if (item.EstadoEvento == "Rechazado" && !string.IsNullOrEmpty(item.MotivoRechazo))
                            {
                                <div class="alert alert-danger p-2 rounded-3 mb-2">
                                    <small><i class="bi bi-info-circle me-1"></i> <strong>Motivo:</strong> @item.MotivoRechazo</small>
                                </div>
                            }

                            @* 👤 ORGANIZADOR *@
                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-person-circle text-secondary me-2"></i>
                                <span class="small text-muted">Por: <b class="text-dark">@(item.Organizador?.UserName?.Split('@')[0] ?? "Staff")</b></span>
                            </div>

                            <p class="card-text text-muted small mb-3" style="min-height: 40px;">@item.Descripcion</p>

                            @* 🗓️ FECHA Y HORA *@
                            <div class="mb-3">
                                <p class="mb-1 text-danger small fw-bold">
                                    <i class="bi bi-calendar-check-fill me-1"></i>
                                    @item.FechaInicio.ToString("dd/MM/yyyy")
                                </p>
                                <p class="mb-0 text-muted small">
                                    <i class="bi bi-clock me-1"></i>
                                    @item.FechaInicio.ToString("hh:mm tt") - @item.FechaFin.ToString("hh:mm tt")
                                </p>
                            </div>

                            @* 📍 LUGAR *@
                            <div class="p-2 rounded-3 mb-3" style="background-color: #f8f9fa; border-left: 4px solid #ffc107;">
                                <p class="text-uppercase text-muted fw-bold mb-1" style="font-size: 0.6rem; letter-spacing: 0.5px;">Recinto Villa Olímpica</p>
                                <p class="mb-0 text-warning fw-bold small">
                                    <i class="bi bi-geo-alt-fill me-1"></i> @(item.Lugar?.Nombre ?? "Pabellón por asignar")
                                </p>
                            </div>

                            @* PRECIOS *@
                            <div class="bg-light p-2 rounded mb-3 border">
                                <small class="text-muted d-block mb-1 fw-bold text-uppercase" style="font-size: 0.65rem;">Precios</small>
                                <div class="d-flex flex-wrap gap-1">
                                    @if (item.CategoriasTickets != null && item.CategoriasTickets.Any())
                                    {
                                        @foreach (var cat in item.CategoriasTickets.OrderBy(c => c.Precio).Take(2))
                                        {
                                            <span class="badge @(cat.Nombre.ToLower().Contains("vip") ? "bg-warning text-dark" : "bg-primary")" style="font-size: 0.7rem;">
                                                @cat.Nombre: RD$ @cat.Precio.ToString("N0")
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small italic" style="font-size: 0.7rem;">Sin boletas</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 pb-4">
                            <div class="d-grid gap-2 mb-3">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary rounded-pill fw-bold py-2">
                                    <i class="bi bi-eye-fill me-2"></i> Ver Detalles
                                </a>
                            </div>

                            <div class="pt-3 border-top text-center">
                                @if (item.EstadoEvento == "Publicado")
                                {
                                    <a asp-action="Dashboard" asp-route-id="@item.Id" class="btn btn-info text-white btn-sm rounded-pill px-4">
                                        <i class="bi bi-graph-up-arrow me-1"></i> Dashboard
                                    </a>
                                }
                                else if (item.EstadoEvento == "PendienteAprobacion")
                                {
                                    <div class="btn-group shadow-sm" style="border-radius: 10px; overflow: hidden;">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <button type="button" class="btn btn-danger btn-sm"
                                                onclick="confirmarEliminar('@item.Id', '@item.Nombre')">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </div>
                                    <small class="text-warning fw-bold d-block mt-2">
                                        <i class="bi bi-hourglass-split me-1"></i> Esperando aprobación
                                    </small>
                                }
                                else if (item.EstadoEvento == "Rechazado")
                                {
                                    <button type="button" class="btn btn-danger btn-sm rounded-pill"
                                            onclick="confirmarEliminar('@item.Id', '@item.Nombre')">
                                        <i class="bi bi-trash3-fill me-1"></i> Eliminar
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<partial name="_ModalEliminar" />
