@model Baratickets2._0.Models.Evento

@{
    ViewData["Title"] = "Editar Evento";
    bool bloquearHorarioRecinto = ViewBag.BloquearHorarioRecinto == true;
}

@* FullCalendar CSS *@
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet" />
@* ✅ Estilo del calendario *@
<style>
    #calendario {
        min-height: 550px;
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid #dee2e6;
    }
</style>
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="text-primary fw-bold mb-0">Gestionar Evento</h1>
            <p class="text-muted">Actualiza los detalles del evento y sus categorías de boletas.</p>
        </div>
        <span class="badge bg-light text-dark border">ID Evento: @Model.Id</span>
    </div>
    <hr />

    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="OrganizadorId" />

        @if (bloquearHorarioRecinto)
        {
            <div class="alert alert-warning py-2">
                <i class="bi bi-lock-fill me-1"></i>
                Solo el `Admin` puede modificar recinto, fecha y horario de este evento.
            </div>
        }

        <div class="row">
            @* --- COLUMNA IZQUIERDA: DATOS BÁSICOS --- *@
            <div class="col-md-5">
                <div class="card shadow-sm border-0 p-4 mb-4" style="border-radius: 15px;">
                    <h5 class="fw-bold mb-3 text-secondary">Información Principal</h5>

                    <div class="form-group mb-3">
                        <label asp-for="Nombre" class="control-label fw-bold small"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="Organizacion" class="control-label fw-bold">Institución / Organizador</label>
                        <input asp-for="Organizacion" class="form-control" />
                        <span asp-validation-for="Organizacion" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="Descripcion" class="control-label fw-bold small"></label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3">@Model.Descripcion</textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold"><i class="bi bi-building-geo me-2"></i>Recinto Villa Olímpica</label>
                        <select asp-for="LugarId" class="form-select shadow-sm border-2" asp-items="ViewBag.LugarId" id="selectLugar" disabled="@(bloquearHorarioRecinto)">
                            <option value="">-- Selecciona el Pabellón/Recinto --</option>
                        </select>
                        @if (bloquearHorarioRecinto)
                        {
                            <input type="hidden" asp-for="LugarId" />
                        }
                        <span asp-validation-for="LugarId" class="text-danger small"></span>
                        <p class="text-muted small mt-1">Selecciona el lugar específico dentro de la Villa Olímpica.</p>
                    </div>

                    <div class="mb-3">
                        <label>Fecha</label>
                        <input type="date" name="fechaSolo" id="fechaSolo" class="form-control"
                               value="@Model.FechaInicio.ToString("yyyy-MM-dd")" required readonly="@(bloquearHorarioRecinto)" />
                    </div>

                    <div class="row">
                        <div class="col-6">
                            <label>Hora Inicio</label>
                            <input type="time" name="horaInicio" class="form-control"
                                   value="@Model.FechaInicio.ToString("HH:mm")" required readonly="@(bloquearHorarioRecinto)" />
                        </div>
                        <div class="col-6">
                            <label>Hora Fin</label>
                            <input type="time" name="horaFin" class="form-control"
                                   value="@Model.FechaFin.ToString("HH:mm")" required readonly="@(bloquearHorarioRecinto)" />
                        </div>
                    </div>

                    <div class="form-group mt-3">
                        <label asp-for="ImagenUrl" class="control-label fw-bold small">URL del Flyer</label>
                        <input asp-for="ImagenUrl" class="form-control" id="urlInputEdit" />
                        <div class="mt-3 text-center">
                            <img id="previewImagenEdit" src="@Model.ImagenUrl" class="img-fluid rounded shadow-sm" style="max-height: 200px; object-fit: cover;" />
                        </div>
                    </div>
                </div>
            </div>

            @* --- COLUMNA CENTRAL: CALENDARIO --- *@
            <div class="col-md-4">
                <div class="card shadow-sm border-0 p-3 mb-4" style="border-radius: 15px;">
                    <h5 class="fw-bold mb-2 text-secondary">Disponibilidad del Recinto</h5>
                    <div class="mb-2 d-flex gap-2 flex-wrap">
                        <span class="badge bg-danger px-2 py-1" style="font-size:0.65rem;">
                            <i class="bi bi-calendar-x me-1"></i> Ocupado
                        </span>
                        <span class="badge px-2 py-1" style="background-color: #fd7e14; font-size:0.65rem;">
                            <i class="bi bi-building me-1"></i> Alquiler
                        </span>
                        <span class="badge bg-success px-2 py-1" style="font-size:0.65rem;">
                            <i class="bi bi-calendar-check me-1"></i> Disponible
                        </span>
                    </div>
                    <div id="calendario" style="border-radius: 10px; overflow: hidden; border: 1px solid #dee2e6;"></div>
                    <small class="text-muted mt-2 d-block">
                        <i class="bi bi-info-circle me-1"></i> Haz click en un día para preseleccionar la fecha.
                    </small>
                </div>
            </div>

            @* --- COLUMNA DERECHA: CATEGORÍAS --- *@
            <div class="col-md-3">
                <div class="card shadow-sm border-0 p-4" style="border-radius: 15px; background-color: #f8f9fa;">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0 text-secondary">Categorías de Boletas</h5>
                        <button type="button" id="btnAddCategoryEdit" class="btn btn-sm btn-dark rounded-pill">
                            <i class="bi bi-plus-circle me-1"></i> Agregar
                        </button>
                    </div>

                    <div id="categoriesContainerEdit">
                        @if (Model.CategoriasTickets != null)
                        {
                            var index = 0;
                            foreach (var cat in Model.CategoriasTickets)
                            {
                                <div class="row g-2 mb-2 category-row animate__animated animate__fadeIn">
                                    <input type="hidden" name="CategoriasTickets[@index].Id" value="@cat.Id" />
                                    <div class="col-md-5">
                                        <input name="CategoriasTickets[@index].Nombre" class="form-control form-control-sm" value="@cat.Nombre" placeholder="Nombre" required />
                                    </div>
                                    <div class="col-md-3">
                                        <input name="CategoriasTickets[@index].Precio" type="number" class="form-control form-control-sm" value="@cat.Precio" placeholder="Precio" required />
                                    </div>
                                    <div class="col-md-3">
                                        <input name="CategoriasTickets[@index].Capacidad" type="number" class="form-control form-control-sm" value="@cat.Capacidad" placeholder="Cant." required />
                                    </div>
                                    <div class="col-md-1">
                                        <button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="this.parentElement.parentElement.remove()">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                                index++;
                            }
                        }
                    </div>
                    <p class="small text-muted mt-2"><i class="bi bi-info-circle me-1"></i> Puedes modificar nombres, precios o añadir nuevas secciones.</p>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow">Actualizar Evento</button>
                    <a asp-action="Index" class="btn btn-light rounded-pill">Cancelar y Volver</a>
                </div>
            </div>
        </div>
    </form>
</div>

@* FullCalendar JS *@
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const bloquearHorarioRecinto = @bloquearHorarioRecinto.ToString().ToLower();

        // --- CALENDARIO ---
        const selectLugar = document.getElementById('selectLugar');
        let calendar;

              function iniciarCalendario(lugarId) {
            const calendarEl = document.getElementById('calendario');
            if (!calendarEl) return;
            if (calendar) calendar.destroy();

            let esperandoFin = false;
            let horaInicioTemp = null;

            calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: 'es',
                height: 600, // ✅ Más alto
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridDay'
                },
                slotMinTime: '06:00:00',
                slotMaxTime: '24:00:00',
                slotDuration: '00:30:00',
                events: `/Alquileres/EventosOcupados?lugarId=${lugarId}`,
                dateClick: function(info) {
                    if (bloquearHorarioRecinto) return;
                    calendar.changeView('timeGridDay', info.dateStr);
                    document.getElementById('fechaSolo').value = info.dateStr;
                },
                eventClick: function(info) {
                    Swal.fire({
                        title: '⛔ Horario Ocupado',
                        html: `<b>${info.event.title}</b><br>
                               ${info.event.start.toLocaleTimeString('es-DO', {hour:'2-digit', minute:'2-digit'})} -
                               ${info.event.end?.toLocaleTimeString('es-DO', {hour:'2-digit', minute:'2-digit'})}`,
                        icon: 'warning',
                        confirmButtonColor: '#0d6efd'
                    });
                },
                // ✅ Click en slot vacío — primero selecciona inicio, segundo click selecciona fin
                dateClick: function(info) {
                    if (bloquearHorarioRecinto) return;
                    if (info.view.type === 'dayGridMonth') {
                        calendar.changeView('timeGridDay', info.dateStr);
                        document.getElementById('fechaSolo').value = info.dateStr;
                        return;
                    }

                    const hora = info.dateStr.substring(11, 16);

                    if (!esperandoFin) {
                        // Primer click — hora inicio
                        horaInicioTemp = hora;
                        esperandoFin = true;
                        document.querySelector('input[name="horaInicio"]').value = hora;
                        Swal.fire({
                            title: '🕐 Hora inicio seleccionada',
                            html: `<b>${hora}</b> — Ahora haz click en la hora de fin`,
                            icon: 'info',
                            timer: 2000,
                            showConfirmButton: false,
                            toast: true,
                            position: 'top-end'
                        });
                    } else {
                        // Segundo click — hora fin
                        const horaFin = hora;
                        esperandoFin = false;

                        if (horaFin <= horaInicioTemp) {
                            Swal.fire({
                                title: 'Error',
                                text: 'La hora de fin debe ser mayor a la hora de inicio.',
                                icon: 'error',
                                confirmButtonColor: '#0d6efd'
                            });
                            return;
                        }

                        document.querySelector('input[name="horaFin"]').value = horaFin;
                        Swal.fire({
                            title: '✅ Horario listo',
                            html: `Inicio: <b>${horaInicioTemp}</b> — Fin: <b>${horaFin}</b>`,
                            icon: 'success',
                            timer: 2000,
                            showConfirmButton: false,
                            toast: true,
                            position: 'top-end'
                        });
                    }
                },
                customButtons: {
                    volverMes: {
                        text: '← Mes',
                        click: function() {
                            calendar.changeView('dayGridMonth');
                            esperandoFin = false;
                        }
                    }
                },
                selectable: false // ✅ Desactivar arrastre, usar clicks individuales
            });

            calendar.on('viewDidMount', function(info) {
                if (info.view.type === 'timeGridDay') {
                    calendar.setOption('headerToolbar', {
                        left: 'volverMes prev,next',
                        center: 'title',
                        right: ''
                    });
                } else {
                    calendar.setOption('headerToolbar', {
                        left: 'prev,next today',
                        center: 'title',
                        right: 'dayGridMonth,timeGridDay'
                    });
                }
            });

            calendar.render();
        }
        if (selectLugar && !bloquearHorarioRecinto) {
            selectLugar.addEventListener('change', function() {
                if (this.value) iniciarCalendario(this.value);
            });

            // Cargar calendario con el recinto actual al abrir
            if (selectLugar.value) {
                iniciarCalendario(selectLugar.value);
            }
        }

        // --- CATEGORÍAS DINÁMICAS ---
        let categoryIndex = @(Model.CategoriasTickets?.Count ?? 0);

        document.getElementById('btnAddCategoryEdit').addEventListener('click', function () {
            const container = document.getElementById('categoriesContainerEdit');
            const html = `
                <div class="row g-2 mb-2 category-row animate__animated animate__fadeIn">
                    <div class="col-md-5">
                        <input name="CategoriasTickets[${categoryIndex}].Nombre" class="form-control form-control-sm" placeholder="Nombre" required />
                    </div>
                    <div class="col-md-3">
                        <input name="CategoriasTickets[${categoryIndex}].Precio" type="number" class="form-control form-control-sm" placeholder="Precio" required />
                    </div>
                    <div class="col-md-3">
                        <input name="CategoriasTickets[${categoryIndex}].Capacidad" type="number" class="form-control form-control-sm" placeholder="Cant." required />
                    </div>
                    <div class="col-md-1">
                        <button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="this.parentElement.parentElement.remove()">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', html);
            categoryIndex++;
        });

        // --- PREVIEW IMAGEN ---
        const inputUrl = document.getElementById('urlInputEdit');
        const preview = document.getElementById('previewImagenEdit');

        if (inputUrl && preview) {
            inputUrl.addEventListener('input', function () {
                let url = this.value;
                if (url) {
                    preview.src = url;
                    preview.style.display = "block";
                    preview.onerror = function() { this.style.display = "none"; };
                } else {
                    preview.style.display = "none";
                }
            });
        }
    </script>
}
