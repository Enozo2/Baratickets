@model Baratickets2._0.Models.Evento
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Detalles del Evento";
}

<style>
    .event-hero {
        position: relative;
        height: 400px;
        background: url('@Model.ImagenUrl') no-repeat center center;
        background-size: cover;
        border-radius: 0 0 30px 30px;
    }

    .event-hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, rgba(0,0,0,0.2), rgba(0,0,0,0.8));
        border-radius: 0 0 30px 30px;
    }

    .location-badge-hero {
        background: rgba(220, 53, 69, 0.9);
        color: white;
        padding: 8px 15px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        font-weight: bold;
    }

    .content-card {
        border-radius: 20px;
        border: none;
    }

    .ticket-card {
        background: #fff;
        border-radius: 15px;
        transition: transform 0.2s;
        border: 1px solid #eee;
    }

        .ticket-card:hover {
            transform: scale(1.02);
        }

        .ticket-card.vip {
            border-left: 5px solid #ffc107;
            background: #fffdf5;
        }

    .sticky-shop {
        position: sticky;
        top: 20px;
    }
</style>

@* --- HERO SECTION --- *@
<div class="event-hero shadow-lg">
    <div class="event-hero-overlay d-flex align-items-end pb-5">
        <div class="container">
            <span class="badge bg-info text-dark mb-2 px-3 rounded-pill">Evento verificado</span>
            <h1 class="display-4 fw-bold text-white">@Model.Nombre</h1>

            <div class="location-badge-hero shadow-sm">
                <i class="bi bi-geo-alt-fill me-2 text-warning"></i>
                <span>Villa Olímpica, Barahona</span>
            </div>
        </div>
    </div>
</div>

<div class="container mt-5">
    <div class="row g-4">

        @* --- COLUMNA IZQUIERDA: INFORMACIÓN --- *@
        <div class="col-lg-7">
            @* Tarjeta Descripción *@
            <div class="card content-card shadow-sm p-4 mb-4">
                <h4 class="fw-bold mb-3"><i class="bi bi-card-text text-primary me-2"></i>Sobre el Evento</h4>
                <p class="text-secondary fs-5" style="line-height: 1.6;">@Model.Descripcion</p>
            </div>

            @* Tarjetas de Detalles en Grid *@
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card content-card shadow-sm p-3 h-100 border-start border-danger border-4">
                        <label class="text-muted small fw-bold text-uppercase">Fecha y Hora</label>
                        <div class="d-flex align-items-center mt-2">
                            <i class="bi bi-calendar-check fs-3 text-danger me-3"></i>
                            <div>
                                <span class="fw-bold d-block text-capitalize">@Model.FechaInicio.ToString("dddd, dd 'de' MMMM", new System.Globalization.CultureInfo("es-ES"))</span>
                                <small class="text-primary fw-bold">@Model.FechaInicio.ToString("hh:mm tt")</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card content-card shadow-sm p-3 h-100 border-start border-primary border-4">
                        <label class="text-muted small fw-bold text-uppercase">Instalación</label>
                        <div class="d-flex align-items-center mt-2">
                            <i class="bi bi-building fs-3 text-primary me-3"></i>
                            <div>
                                <span class="fw-bold d-block text-primary">@(Model.Lugar?.Nombre ?? "Pabellón por definir")</span>
                                <small class="text-muted">Sector Villa Olímpica</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Tarjeta Organizador *@
            <div class="card content-card shadow-sm p-3 mt-3 bg-light">
                <label class="text-muted small fw-bold text-uppercase">Organizado por</label>
                <div class="d-flex align-items-center mt-2">
                    <i class="bi bi-shield-check fs-3 text-success me-3"></i>
                    <span class="fw-bold">@(string.IsNullOrWhiteSpace(Model.Organizacion) ? "Villa Olímpica Staff" : Model.Organizacion)</span>
                </div>
            </div>

            @* BOTÓN CÓMO LLEGAR (Dentro de la columna info) *@
            <div class="mt-4 text-center">
                @{
                    string queryMapa = "Villa Olimpica, Barahona, Republica Dominicana " + (Model.Lugar?.Nombre ?? "");
                    string urlMapa = "https://www.google.com/maps/search/?api=1&query=" + System.Net.WebUtility.UrlEncode(queryMapa);
                }
                <a href="@urlMapa" target="_blank" class="btn btn-dark rounded-pill px-5 py-3 shadow-lg fw-bold">
                    <i class="bi bi-geo-alt-fill me-2 text-danger"></i>¿Cómo llegar al evento?
                </a>
                
            </div>
        </div>

@* --- COLUMNA DERECHA: COMPRA DE BOLETAS --- *@
        <div class="col-lg-5">
            <div class="sticky-shop">
                <div class="card content-card shadow-lg p-4 border-0 bg-light">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-dark text-white p-2 rounded-circle me-3">
                            <i class="bi bi-ticket-perforated fs-4"></i>
                        </div>
                        <h4 class="fw-bold mb-0">Compra de boletas</h4>
                    </div>

                    @if (Model.CategoriasTickets == null || !Model.CategoriasTickets.Any())
                    {
                        <div class="alert alert-warning rounded-4 border-0 text-center">
                            No hay boletas disponibles.
                        </div>
                    }
                    else
                    {
                        @foreach (var cat in Model.CategoriasTickets)
                        {
                            <div class="ticket-card p-3 mb-3 shadow-sm @(cat.Nombre.ToLower().Contains("vip") ? "vip" : "")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="fw-bold mb-1">@cat.Nombre</h6>
                                        <span class="text-success fw-bold h5">RD$ @cat.Precio.ToString("N0")</span>
                                        <br />
                                        <small class="text-muted"><i class="bi bi-info-circle"></i> Disponibles: @cat.Capacidad</small>
                                    </div>
                                    <div>
                                            @if (cat.Capacidad <= 0)
                                            {
                                                <button class="btn btn-secondary btn-sm disabled rounded-pill" disabled>Agotado</button>
                                            }
                                            @* 🛑 BLOQUEO PARA ADMIN Y ORGANIZADOR *@
                                            else if (User.Identity.IsAuthenticated && (Model.OrganizadorId == UserManager.GetUserId(User) || User.IsInRole("Admin")))
                                            {
                                                <div class="text-center">
                                                    <button class="btn btn-outline-secondary btn-sm rounded-pill px-3 disabled mb-1">
                                                        <i class="bi bi-shield-lock-fill me-1"></i> Acceso de personal
                                                    </button>
                                                    <br />
                                                    <small class="text-muted" style="font-size: 0.65rem;">Restringido para administradores y organizadores</small>
                                                </div>
                                            }
                                            else
                                            {
                                                <form asp-controller="Tickets" asp-action="ProcesarPago" method="get">
                                                    <input type="hidden" name="eventoId" value="@Model.Id" />
                                                    <input type="hidden" name="categoriaId" value="@cat.Id" />
                                                    <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold shadow-sm">
                                                        Comprar
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
