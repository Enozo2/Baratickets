@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Nueva Contraseña";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 75vh;">
        <div class="col-md-5">
            <div class="card shadow-lg border-0" style="border-radius: 20px; overflow: hidden;">
                <div class="bg-primary bg-gradient py-4 text-center">
                    <i class="bi bi-shield-lock-fill text-white" style="font-size: 2.5rem;"></i>
                    <h3 class="text-white fw-bold mt-2">BaraTickets 2.0</h3>
                </div>

                <div class="card-body p-4 p-md-5">
                    <h4 class="text-center fw-bold mb-4">Crea tu nueva clave</h4>
                    
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        
                        @* El Token oculto es vital *@
                        <input asp-for="Input.Code" type="hidden" />

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control border-0 bg-light" placeholder="email" style="border-radius: 12px;" />
                            <label asp-for="Input.Email">Confirma tu correo</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control border-0 bg-light" placeholder="clave" style="border-radius: 12px;" />
                            <label asp-for="Input.Password">Nueva Contraseña</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.ConfirmPassword" class="form-control border-0 bg-light" placeholder="repetir" style="border-radius: 12px;" />
                            <label asp-for="Input.ConfirmPassword">Repetir Contraseña</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-pill shadow">
                            Actualizar Contraseña
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>