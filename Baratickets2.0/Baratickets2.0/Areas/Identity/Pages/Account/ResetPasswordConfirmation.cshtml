@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Contraseña Cambiada";
}

<div class="container text-center mt-5">
    <div class="card shadow border-0 p-5 d-inline-block" style="border-radius: 20px;">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
        <h2 class="fw-bold mt-3">¡Todo listo!</h2>
        <p class="text-muted">Tu contraseña ha sido restablecida correctamente.</p>
        <a asp-page="./Login" class="btn btn-primary rounded-pill px-5 py-2 fw-bold">Iniciar Sesión</a>
    </div>
</div>