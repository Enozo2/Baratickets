@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "¿Olvidaste tu contraseña?";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 75vh;">
        <div class="col-md-5">
            <div class="card shadow-lg border-0" style="border-radius: 20px; overflow: hidden;">
                @* Cabecera con degradado azul como en el Login *@
                <div class="bg-primary bg-gradient py-4 text-center text-white">
                    <i class="bi bi-patch-question-fill" style="font-size: 2.5rem;"></i>
                    <h3 class="fw-bold mt-2">Recuperar Acceso</h3>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <p class="text-muted">Introduce tu correo y te enviaremos un enlace para restablecer tu clave.</p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.Email" class="form-control border-0 bg-light" placeholder="correo@ejemplo.com" style="border-radius: 12px;" />
                            <label asp-for="Input.Email" class="text-muted">Correo electrónico</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm rounded-pill">
                            Enviar Enlace de Recuperación
                        </button>

                        <div class="text-center mt-4">
                            <a asp-page="./Login" class="text-decoration-none small fw-bold">
                                <i class="bi bi-arrow-left me-1"></i> Volver al Inicio
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>