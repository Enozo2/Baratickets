@page
@model LockoutModel
@{
    ViewData["Title"] = "Acceso Bloqueado";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 75vh;">
        <div class="col-md-5 text-center">
            <div class="card shadow-lg border-0" style="border-radius: 20px; overflow: hidden;">
                @* Cabecera Roja de Advertencia *@
                <div class="bg-danger bg-gradient py-4">
                    <i class="bi bi-exclamation-octagon-fill text-white" style="font-size: 3rem;"></i>
                    <h3 class="text-white fw-bold mt-2">Cuenta Bloqueada</h3>
                </div>

                <div class="card-body p-5">
                    <h4 class="fw-bold mb-3">Demasiados intentos fallidos</h4>
                    <p class="text-muted">
                        Por razones de seguridad, hemos bloqueado temporalmente tu acceso a <strong>BaraTickets 2.0</strong>.
                    </p>

                    <div class="alert alert-warning border-0 small mb-4">
                        <i class="bi bi-clock-history me-2"></i>
                        Tu cuenta se desbloqueará automáticamente en <strong>15 minutos</strong>.
                    </div>

                    <p class="small">
                        Hemos enviado una alerta a tu correo electrónico con instrucciones adicionales.
                    </p>

                    <hr class="my-4">

                    <div class="d-grid">
                        <a asp-page="./Login" class="btn btn-outline-primary fw-bold py-2 rounded-pill">
                            Volver al Inicio
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient {
        background: linear-gradient(45deg, #dc3545, #a71d2a) !important;
    }

    .card {
        transition: transform 0.3s;
    }

        .card:hover {
            transform: translateY(-5px);
        }
</style>