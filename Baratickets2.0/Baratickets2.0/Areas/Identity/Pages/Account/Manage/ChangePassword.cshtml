@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Cambiar Contraseña";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 text-center">
                    <h4 class="mb-0 fw-bold text-danger"><i class="bi bi-shield-lock me-2"></i>@ViewData["Title"]</h4>
                </div>
                <div class="card-body p-4">
                    <partial name="_StatusMessage" for="StatusMessage" />

                    @* IMPORTANTE: Todo debe ir dentro de un <form> *@
                    <form id="change-password-form" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                        @* Contraseña Actual *@
                        <div class="mb-3">
                            <label asp-for="Input.OldPassword" class="form-label fw-bold">Contraseña Actual</label>
                            <div class="input-group">
                                <input asp-for="Input.OldPassword" class="form-control password-input" type="password" />
                                <button class="btn btn-outline-secondary toggle-password" type="button">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
                        </div>

                        @* Nueva Contraseña *@
                        <div class="mb-3">
                            <label asp-for="Input.NewPassword" class="form-label fw-bold">Nueva Contraseña</label>
                            <div class="input-group">
                                <input asp-for="Input.NewPassword" class="form-control password-input" type="password" />
                                <button class="btn btn-outline-secondary toggle-password" type="button">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                        </div>

                        @* Confirmar Nueva Contraseña *@
                        <div class="mb-4">
                            <label asp-for="Input.ConfirmPassword" class="form-label fw-bold">Confirmar Nueva Contraseña</label>
                            <div class="input-group">
                                <input asp-for="Input.ConfirmPassword" class="form-control password-input" type="password" />
                                <button class="btn btn-outline-secondary toggle-password" type="button">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill shadow-sm">
                                Actualizar Contraseña
                            </button>
                            <a asp-controller="Usuarios" asp-action="MiCuenta" class="btn btn-link text-decoration-none text-muted">
                                Cancelar y volver
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 1. Lógica para el "ojito" (Ver/Ocultar contraseña)
            document.querySelectorAll('.toggle-password').forEach(button => {
                button.addEventListener('click', function (e) {
                    e.preventDefault(); // Evita cualquier acción por defecto

                    // Buscamos el input que está dentro del mismo "input-group"
                    const input = this.closest('.input-group').querySelector('.password-input');
                    const icon = this.querySelector('i');

                    if (input.type === "password") {
                        input.type = "text";
                        icon.classList.replace('bi-eye', 'bi-eye-slash');
                    } else {
                        input.type = "password";
                        icon.classList.replace('bi-eye-slash', 'bi-eye');
                    }
                });
            });

            // 2. Redirección automática si hay éxito
            const successAlert = document.querySelector('.alert-success');
            if (successAlert) {
                setTimeout(function() {
                    window.location.href = '/Usuarios/MiCuenta';
                }, 2000);
            }
        });
    </script>
}