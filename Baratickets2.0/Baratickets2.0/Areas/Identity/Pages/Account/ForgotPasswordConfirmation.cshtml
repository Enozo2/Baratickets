@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Correo Enviado";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 75vh;">
        <div class="col-md-5 text-center">
            <div class="card shadow-lg border-0" style="border-radius: 20px; overflow: hidden;">
                @* Cabecera con Degradado Azul para dar continuidad *@
                <div class="bg-primary bg-gradient py-4">
                    <i class="bi bi-envelope-check-fill text-white" style="font-size: 3rem;"></i>
                    <h3 class="text-white fw-bold mt-2">¡Revisa tu bandeja!</h3>
                </div>

                <div class="card-body p-5">
                    <h4 class="fw-bold mb-3">Enlace enviado con éxito</h4>
                    <p class="text-muted">
                        Hemos enviado las instrucciones para restablecer tu contraseña al correo que proporcionaste.
                    </p>

                    <div class="alert alert-info border-0 small mb-4" style="background-color: #f0f7ff;">
                        <i class="bi bi-info-circle me-2"></i>
                        Si no lo ves en unos minutos, revisa tu carpeta de <strong>Correo no deseado (Spam)</strong>.
                    </div>

                    <hr class="my-4">

                    <div class="d-grid">
                        <a asp-page="./Login" class="btn btn-primary fw-bold py-2 rounded-pill shadow-sm">
                            Regresar al Inicio de Sesión
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

